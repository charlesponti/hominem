{
  "name": "@hominem/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "types": "./build/index.d.ts",
  "typesVersions": {
    "*": {
      ".": [
        "build/index.d.ts"
      ],
      "types/*": [
        "build/schema/*.types.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "default": "./build/index.js"
    },
    "./schema/*": {
      "types": "./build/schema/*.schema.d.ts",
      "import": "./build/schema/*.schema.js",
      "default": "./build/schema/*.schema.js"
    },
    "./schema/tables": {
      "types": "./build/schema/tables.d.ts",
      "import": "./build/schema/tables.js",
      "default": "./build/schema/tables.js"
    },
    "./google-calendar.service": {
      "types": "./build/google-calendar.service.d.ts",
      "import": "./build/google-calendar.service.js",
      "default": "./build/google-calendar.service.js"
    },
    "./types/*": {
      "types": "./build/schema/*.types.d.ts",
      "import": "./build/schema/*.types.js",
      "default": "./build/schema/*.types.js"
    },
    "./services/*": {
      "types": "./build/services/*.d.ts",
      "import": "./build/services/*.js",
      "default": "./build/services/*.js"
    },
    "./services/finance/*": {
      "types": "./build/services/finance/*.d.ts",
      "import": "./build/services/finance/*.js",
      "default": "./build/services/finance/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "prepare": "bun run build",
    "clean": "rm -rf build",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:migrate:test": "NODE_ENV=test bunx drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hominem/utils": "workspace:*",
    "csv-parser": "^3.2.0",
    "drizzle-orm": "0.45.1",
    "drizzle-zod": "^0.7.0",
    "openai": "4.83.0",
    "postgres": "^3.4.5",
    "uuid": "^11.1.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "dotenv": "^16.4.7",
    "drizzle-kit": "0.31.8",
    "typescript": "5.9.3",
    "vitest": "^4.0.16"
  }
}
