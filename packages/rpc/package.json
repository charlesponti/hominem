{
  "name": "@hominem/rpc",
  "version": "0.1.0",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./src/client.ts"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./src/react/index.ts"
    },
    "./ssr": {
      "types": "./dist/ssr/index.d.ts",
      "default": "./src/ssr/index.ts"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./src/types/index.ts"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "default": "./src/types/*.ts"
    },
    "./schemas/*": {
      "types": "./dist/schemas/*.d.ts",
      "default": "./src/schemas/*.ts"
    },
    "./contracts": {
      "types": "./dist/contracts/app.d.ts",
      "default": "./src/contracts/app.ts"
    },
    "./domains/*": {
      "types": "./dist/domains/*.d.ts",
      "default": "./src/domains/*.ts"
    }
  },
  "scripts": {
    "build": "bunx tsgo --incremental",
    "typecheck": "bunx tsgo --noEmit --incremental"
  },
  "dependencies": {
    "@hominem/auth": "workspace:*",
    "@tanstack/react-query": "5.90.16",
    "hono": "^4.12.6",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/react": "19.2.10",
    "@types/react-dom": "19.1.7",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "react": "19.2.0"
  }
}
